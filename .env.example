# any2video configuration — copy to `.env` (gitignored) and fill in what you need.
# Everything here is optional: with no keys at all, the pipeline uses the free
# edge-tts voice and skips Telegram delivery.

# --- Text-to-speech ---------------------------------------------------------
# If set, Google Cloud TTS (Chirp 3 HD) is used for Google voices in a plan.
# Leave empty to use the free edge-tts fallback (no key needed).
GOOGLE_TTS_API_KEY=

# --- Telegram delivery (optional) ------------------------------------------
# Only needed if you want to send the transcript / final video to a chat.
ANY2VIDEO_TG_BOT_TOKEN=
ANY2VIDEO_TG_CHAT_ID=

# --- Secrets pointer (optional) --------------------------------------------
# Load an additional .env from elsewhere, so secrets can live outside the repo.
# ANY2VIDEO_ENV_FILE=/absolute/path/to/other.env

# --- Path overrides (optional) ---------------------------------------------
# ANY2VIDEO_WORKSPACE=./workspace
# ANY2VIDEO_SKILL_DIR=./skill
