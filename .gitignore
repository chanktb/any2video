# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/

# Secrets / environment (NEVER commit — code reads these from local .env pointers)
*.env
.env
secrets/

# Generated outputs — per-run videos, audio, screenshots, plans
workspace/
*.mp4
*.webm

# Third-party reference material (vendored study repos + curated sample videos —
# not ours to redistribute)
references/

# Operator-private tooling — NEVER public. Ships nothing to GitHub: FB-page
# publisher + its .env (page id / access token). A fork won't have this dir.
local/

# Quarantined BGM — Content-ID-flagged tracks moved out of the pool (Kevin MacLeod
# etc). Kept locally for reference only; must NOT ship (they trigger FB/YT claims).
skill/templates/bgm/_disabled/

# OS cruft
.DS_Store
Thumbs.db
